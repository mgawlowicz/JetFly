datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Booking {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Dane Klienta
  firstName     String
  lastName      String
  email         String
  phone         String
  
  // Dane Lotu
  departure     String
  arrival       String
  distance      Int
  datetime      String
  jetSlug       String
  passengers    Int
  
  // Finanse & Status
  price         Float
  sustainabilityTax Float
  vat           Float
  bespokeServices String
  totalPrice    Float
  
  status        String   @default("PENDING_PAYMENT")
  paymentId     String?
}
